# ========================================
# VARIÁVEIS DE AMBIENTE - DesejosMS
# ========================================
# IMPORTANTE: 
# 1. Copie este arquivo para .env  (cp .env.example .env)
# 2. Preencha com suas credenciais REAIS
# 3. NUNCA envie o arquivo .env para o GitHub!
# 4. No Vercel, configure essas vars em: Project Settings → Environment Variables
# ========================================

# ========================================
# SUPABASE - Banco de Dados
# Obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
# ========================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# MERCADO PAGO
# As chaves do MP são configuradas pelo admin no painel (salvas no Supabase)
# Mas você pode definir aqui como valor padrão/fallback
# Obtenha em: https://www.mercadopago.com.br/developers → Credenciais de Produção
# ========================================
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# ========================================
# CONFIGURAÇÕES GERAIS
# ========================================
NODE_ENV=production
PORT=3000

# URL do site (IMPORTANTE para o webhook funcionar)
# Ex: https://desejosms.vercel.app ou https://desejosms.com.br
SITE_URL=https://seu-site.vercel.app

# ========================================
# SEGURANÇA DO WEBHOOK
# Gere uma string aleatória longa: openssl rand -hex 32
# ========================================
WEBHOOK_SECRET=sua-string-secreta-aleatoria-de-32-chars-aqui

# ========================================
# NOTIFICAÇÕES (CRON JOBS E APROVAÇÕES)
# ========================================

# Resend: API para envio de e-mails gratuitos (100/dia) - Pegue no painel do resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Evolution API: Serviço de disparo de WhatsApp via VPS 
EVOLUTION_API_URL=http://api-whatsapp.seudominio.com:8080
EVOLUTION_API_KEY=sua_apikey_global
EVOLUTION_INSTANCE_NAME=desejosms
